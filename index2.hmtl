<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SikoTadabbur AI - @rachmandias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Amiri&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #fafafa; }
        .arabic { font-family: 'Amiri', serif; direction: rtl; }
        .shimmer { background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%); background-size: 200% 100%; animation: shim 1.5s infinite; }
        @keyframes shim { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center p-4">

    <header class="text-center mt-10 mb-8">
        <h1 class="text-3xl font-black text-gray-900 tracking-tight">Which Ayah Fits Me?</h1>
        <p class="text-emerald-600 text-[10px] font-bold uppercase tracking-[0.3em]">Local LLM Node | Pixel Fold</p>
    </header>

    <div class="w-full max-w-xl bg-white rounded-[2.5rem] shadow-2xl p-4 mb-6 border border-gray-100">
        <textarea id="userInput" placeholder="Ceritakan perasaanmu..." 
            class="w-full px-4 py-2 bg-transparent focus:outline-none text-gray-700 text-lg resize-none h-32"></textarea>
        <div class="flex justify-end pt-2">
            <button onclick="askAI()" id="sendBtn" class="bg-emerald-600 text-white px-10 py-4 rounded-3xl font-bold shadow-lg shadow-emerald-100 active:scale-95 transition-all">
                Cari Petunjuk
            </button>
        </div>
    </div>

    <div id="resultArea" class="w-full max-w-xl hidden">
        <div id="loading" class="h-40 shimmer rounded-[2.5rem] mb-6"></div>
        <div id="output" class="bg-white rounded-[2.5rem] shadow-xl p-8 border border-emerald-50">
            <div id="aiResponse" class="space-y-6"></div>
            <button onclick="shareWA()" class="mt-8 w-full py-4 bg-emerald-50 text-emerald-700 rounded-2xl font-bold text-xs uppercase tracking-widest hover:bg-emerald-100 transition-all">
                Bagikan ke WhatsApp
            </button>
        </div>
    </div>

    <script>
        async function askAI() {
            const input = document.getElementById('userInput').value;
            if (!input) return;

            const resultArea = document.getElementById('resultArea');
            const loading = document.getElementById('loading');
            const output = document.getElementById('output');
            const sendBtn = document.getElementById('sendBtn');

            resultArea.classList.remove('hidden');
            loading.classList.remove('hidden');
            output.classList.add('hidden');
            sendBtn.disabled = true;
            sendBtn.innerText = "...";

            const prompt = `User feels: "${input}". 
            Find 1 relevant Quran Ayah/Hadith. 
            ONLY output in this HTML:
            <p class="arabic text-4xl leading-loose text-right text-gray-800">ARABIC_TEXT</p>
            <p class="text-emerald-600 font-black text-[10px] tracking-widest uppercase mb-1">REFERENCE</p>
            <p class="text-gray-600 italic text-md">"TRANSLATION_ID"</p>
            <div class="mt-4 p-4 bg-emerald-50 rounded-xl text-emerald-800 text-xs italic"><b>Tadabbur:</b> ADVICE_ID</div>`;

            try {
                const res = await fetch('http://localhost:11434/api/generate', {
                    method: 'POST',
                    body: JSON.stringify({ model: 'llama3.2:1b', prompt: prompt, stream: false })
                });
                const data = await res.json();
                document.getElementById('aiResponse').innerHTML = data.response;
                loading.classList.add('hidden');
                output.classList.remove('hidden');
            } catch (e) {
                alert("Gagal koneksi ke Ollama server!");
            } finally {
                sendBtn.disabled = false;
                sendBtn.innerText = "Cari Petunjuk";
            }
        }

        function shareWA() {
            const text = encodeURIComponent("Tadabbur Siko hari ini: \n\n" + document.getElementById('aiResponse').innerText);
            window.open(`https://wa.me/?text=${text}`);
        }
    </script>
</body>
</html>
